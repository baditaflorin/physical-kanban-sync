{
  "name": "physical-kanban-sync",
  "version": "0.1.0",
  "description": "Browser-first physical sticky-note Kanban that scans AprilTags and syncs board state to collaborators.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baditaflorin/physical-kanban-sync.git"
  },
  "bugs": {
    "url": "https://github.com/baditaflorin/physical-kanban-sync/issues"
  },
  "homepage": "https://baditaflorin.github.io/physical-kanban-sync/",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "prebuild": "node scripts/clean-pages.mjs",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "playwright test",
    "pages-preview": "node scripts/pages-preview.mjs"
  },
  "dependencies": {
    "@mlc-ai/web-llm": "^0.2.83",
    "@tanstack/react-query": "^5.100.9",
    "apriltag": "^2.0.3",
    "idb": "^8.0.3",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "y-webrtc": "^10.3.0",
    "yjs": "^13.6.30",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
